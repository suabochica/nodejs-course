{
  "tasks": {
    "dev": "deno run --watch main.ts", 
    "build": "deno run npm:build",
    "all": "first ; second",
    "sequential": "first && second",
    "backup": "first || second",
    "async": "first & second"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@0.177.0",
    "@std/text": "jsr:@std/text@0.177.0"
  },
  "lint": {
    "include": ["src/"],
    "exclude": ["src/testdata/", "src/fixtures/**/*.ts"],
    "rules": {
      "include": ["ban-untagged-todo"],
      "exclude": ["no-unused-vars"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 4,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["src/"],
    "exclude": ["src/testdata/", "src/fixtures/**/*.ts"]
  }
}